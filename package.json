{
	"name": "servicenow-mcp-server",
	"version": "0.1.0",
	"private": true,
	"description": "ServiceNow MCP Server v2 scaffold",
	"type": "module",
	"scripts": {
		"start": "node src/index.js",
		"start:stdio": "set MCP_TRANSPORT=stdio&&node src/index.js",
		"smoke": "node src/index.js --smoke",
		"smoke:summary": "node src/index.js --smoke-summary",
		"test": "node --test tests/**/*.test.js",
		"build:companion": "node scripts/build-companion-updateset.js",
		"deploy:companion": "node scripts/deploy-companion-update-set.js",
		"test:companion:live": "node scripts/test-companion-live.js",
		"test:g2": "node scripts/test-g2-validation.js",
		"test:g2:live": "set GATE_TEST_TARGET=live&&set ALLOW_LIVE_GATE_TESTS=true&&set ALLOW_LIVE_GATE_WRITES=true&&node scripts/test-g2-validation.js",
		"test:g5": "node scripts/test-g5-validation.js",
		"test:g5:live": "set GATE_TEST_TARGET=live&&set ALLOW_LIVE_GATE_TESTS=true&&set ALLOW_LIVE_GATE_WRITES=true&&node scripts/test-g5-validation.js",
		"test:g6": "node scripts/test-g6-validation.js",
		"test:g6:live": "set GATE_TEST_TARGET=live&&set ALLOW_LIVE_GATE_TESTS=true&&set ALLOW_LIVE_GATE_WRITES=true&&node scripts/test-g6-validation.js",
		"test:g4": "node scripts/test-g4-validation.js",
		"test:g4:live:gate": "set GATE_TEST_TARGET=live&&set ALLOW_LIVE_GATE_TESTS=true&&set ALLOW_LIVE_GATE_WRITES=true&&node scripts/test-g4-validation.js",
		"test:g4:live": "node scripts/test-g4-integration-live.js",
		"test:gates:g1-g6:live": "npm run test:live && npm run test:live:mcp && npm run test:g2:live && npm run test:g4:live:gate && npm run test:g4:live && npm run test:g5:live && npm run test:g6:live",
		"test:live": "node scripts/test-live-connection.js",
		"test:live:mcp": "node scripts/test-live-mcp-transport.js"
	},
	"engines": {
		"node": ">=18"
	}
}
