{
	"name": "servicenow-mcp-server",
	"version": "0.1.0",
	"private": true,
	"description": "ServiceNow MCP Server v2 scaffold",
	"type": "module",
	"scripts": {
		"start": "node src/index.js",
		"start:stdio": "set MCP_TRANSPORT=stdio&&node src/index.js",
		"smoke": "node src/index.js --smoke",
		"smoke:summary": "node src/index.js --smoke-summary",
		"test": "node scripts/test-runner.js --group ci",
		"test:all": "node scripts/test-runner.js",
		"test:unit": "node --test tests/**/*.test.js",
		"build:companion": "node scripts/build-companion-updateset.js",
		"deploy:companion": "node scripts/deploy-companion-update-set.js",
		"test:companion:live": "node scripts/test-companion-live.js",
		"structure:publish": "node scripts/publish-project-structure.js --write",
		"structure:check": "node scripts/publish-project-structure.js --check"
	},
	"engines": {
		"node": ">=18"
	}
}
