# ============================================================================
# ServiceNow MCP Server v2 - Public Environment Template
# Copy this file to `.env` and fill in your local credentials.
# Do NOT commit `.env`.
# ============================================================================

# ----------------------------------------------------------------------------
# MCP runtime
# ----------------------------------------------------------------------------
MCP_EDITION=dev
MCP_TRANSPORT=http-sse
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=3001
MCP_SERVER_PATH=/mcp

# ----------------------------------------------------------------------------
# Default ServiceNow instance (single-instance mode)
# ----------------------------------------------------------------------------
SN_INSTANCE_KEY=default
SN_INSTANCE_URL=https://your-instance.service-now.com

# Auth mode: oauth | basic
SN_AUTH_MODE=basic

# OAuth (recommended for production)
SN_CLIENT_ID=
SN_CLIENT_SECRET=
SN_OAUTH_ACCESS_TOKEN=

# Basic auth (dev/test only; avoid for production)
SN_USERNAME=your.servicenow.username
SN_PASSWORD=your.servicenow.password

# ----------------------------------------------------------------------------
# Multi-instance mode (optional)
# If set, this takes precedence over SN_INSTANCE_* defaults.
# ----------------------------------------------------------------------------
# SN_DEFAULT_INSTANCE=dev
# SN_INSTANCES_JSON={"dev":{"instanceUrl":"https://dev.service-now.com","auth":{"mode":"basic","username":"dev_user","password":"dev_pass"}},"test":{"instanceUrl":"https://test.service-now.com","auth":{"mode":"oauth","clientId":"...","clientSecret":"...","accessToken":"..."}}}

# ----------------------------------------------------------------------------
# ServiceNow client resilience
# ----------------------------------------------------------------------------
SN_RETRY_MAX_ATTEMPTS=3
SN_RETRY_BASE_DELAY_MS=200
SN_REQUEST_TIMEOUT_MS=4000

# ----------------------------------------------------------------------------
# Safety tiering
# ----------------------------------------------------------------------------
MCP_TIER_MAX=T0

# ----------------------------------------------------------------------------
# Policy controls
# ----------------------------------------------------------------------------
MCP_ALLOWED_SCOPES=global
MCP_DENY_GLOBAL_WRITES=false
MCP_ENFORCE_CHANGESET_SCOPE=false
MCP_CHANGESET_SCOPE=

# Break-glass behavior
MCP_BREAK_GLASS_ENABLED=false
MCP_EXCEPTION_ALLOWLIST=

# ----------------------------------------------------------------------------
# Planned validation settings (reserved for upcoming validation engine work)
# ----------------------------------------------------------------------------
# VALIDATION_RULEPACK_VERSION=1.0.0
# VALIDATION_FAIL_ON=CRITICAL
